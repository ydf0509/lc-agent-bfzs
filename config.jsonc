{
  // ----- UI -----
  "ui": {
      // 网页左上角显示的应用名称，默认 "lc_agent"
      "app_name": "心有灵犀"
  },

  // LLM 提供商配置
  "provider": {
    "litellm": {
      "api_key": "sk-no-key-needed",
      "base_url": "http://localhost:4000/v1",
      "models": [
        // === 阿里百炼 ===
        // {"id": "ali-qwen3.6-plus", "context_limit": 200000, "max_output_tokens": 65536},
        // {"id": "ali-qwen3.6-flash", "context_limit": 200000, "max_output_tokens": 65536},
        // {"id": "ali-deepseek-v4-pro", "context_limit": 200000, "max_output_tokens": 65536},
        // {"id": "ali-deepseek-v4-flash", "context_limit": 200000, "max_output_tokens": 65536},
        // {"id": "ali-deepseek-v3.2", "context_limit": 200000, "max_output_tokens": 65536},
        // {"id": "ali-kimi-k2.6", "context_limit": 200000, "max_output_tokens": 65536},
        // {"id": "ali-kimi-k2.5", "context_limit": 200000, "max_output_tokens": 65536},
        // {"id": "ali-glm-5.1", "context_limit": 200000, "max_output_tokens": 65536},
        // {"id": "ali-glm-5", "context_limit": 200000, "max_output_tokens": 65536},
        // {"id": "ali-MiniMax-M2.5", "context_limit": 200000, "max_output_tokens": 65536},
        // === DeepSeek 官方 ===
        {"id": "ark-deepseek-v4-flash", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "zzz-gpt-5.4", "context_limit": 400000, "max_output_tokens": 65536},
        {"id": "zzz-gpt-5.5", "context_limit": 400000, "max_output_tokens": 65536},

        {"id": "zzz-auto-gpt-5.4", "context_limit": 400000, "max_output_tokens": 65536},
        {"id": "zzz-auto-gpt-5.5", "context_limit": 400000, "max_output_tokens": 65536},

        {"id": "zzz-fallback-gpt-5.4", "context_limit": 400000, "max_output_tokens": 65536},
        {"id": "zzz-fallback-gpt-5.5", "context_limit": 400000, "max_output_tokens": 65536},

        {"id": "ds-deepseek-v4-pro", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "ds-deepseek-v4-flash", "context_limit": 200000, "max_output_tokens": 65536},
        // === 字节方舟 Coding Plan ===
        {"id": "ark-code-latest", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "ark-doubao-seed-code", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "ark-deepseek-v3.2", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "ark-doubao-seed-2.0-code", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "ark-doubao-seed-2.0-pro", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "ark-doubao-seed-2.0-lite", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "ark-minimax-m2.7", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "ark-glm-5.1", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "ark-kimi-k2.6", "context_limit": 200000, "max_output_tokens": 65536},

        {"id": "ark-deepseek-v4-pro", "context_limit": 200000, "max_output_tokens": 65536},
        // === 公司内部 ===
        {"id": "com-qwen3.5-397b", "context_limit": 200000, "max_output_tokens": 65536},
        {"id": "com-qwen3.6-35b", "context_limit": 200000, "max_output_tokens": 65536}
      ]
    }
  },

  "agent": {
    "system_prompt": "你是一个智能助手，擅长文件管理、数据分析和日常辅助任务。请用中文回答问题。",
    "default_model": "ds-deepseek-v4-flash",
    "streaming": true,
    "summarization": {
      "enabled": false,
      "model": "",
      "trigger": ["fraction", 0.85],
      "keep": ["fraction", 0.20]
    }
  },

  "database": {
    "url": "sqlite+aiosqlite:///./bfzs_data.db",
    "checkpoint_path": "./bfzs_checkpoints.db"
  },

  "skills": ["./myskills","D:/codes/lc-agent-bfzs/skills_query_feature"],


  "mcp_servers": {
    // Web 搜索 MCP
    "web-search": {
      "type": "sse",
      "url": "http://localhost:3000/sse",
      "enabled": true
    },

    // 文件系统 MCP：让 AI 读写指定目录的文件，这个是最知名的第三方文件系统MCP
    // ⚠ 必须至少提供一个绝对路径，AI 只能访问列出的目录
    // 如果编程，不要接入这个filesystem mcp，serena就够了，接入太多mcp会浪费tokens和加大ai决策难度。
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "D:/codes/nb_agent_bfzs"]
    },

    // 用户可以先独立方式启动nbrag mcp web服务，也可以使用local模式启动
    "nbrag": {
      "type": "http",
      "url": "http://localhost:9101/mcp"
    },

    // Context7 MCP
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    },

    // Serena 代码分析 MCP — 已修正路径
    // "serena": {
    //   "type": "local",
    //   "command": ["C:/Users/ydf6/.local/bin/serena.exe", "start-mcp-server", "--project", "D:/codes/lc-agent"],
    //   "enabled": true
    // },

    "serena": {
      "type": "http",
      "url": "http://localhost:9102/mcp",
      "enabled": true
    },

    // LangChain 官方文档 MCP
    "docs-langchain": {
      "type": "http",
      "url": "https://docs.langchain.com/mcp"
    },

    // LangChain API 参考 MCP
    "reference-langchain": {
      "type": "http",
      "url": "https://reference.langchain.com/mcp"
    }
  }
}
